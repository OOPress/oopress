#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

// Load environment for CLI
$dotenv = Dotenv\Dotenv::createImmutable(__DIR__ . '/..');
$dotenv->load();

$command = $argv[1] ?? 'help';
$arg2 = $argv[2] ?? '';

match($command) {
    'serve' => serve(),
    'make:model' => makeModel($arg2),
    'make:controller' => makeController($arg2),
    'make:middleware' => makeMiddleware($arg2),
    'make:migration' => makeMigration($arg2),
    'migrate' => migrate(),
    'migrate:rollback' => migrateRollback($arg2),
    'migrate:fresh' => migrateFresh(),
    'migrate:status' => migrateStatus(),
    'cache:clear' => cacheClear(),
    'route:list' => routeList(),
    'db:seed' => dbSeed(),
    default => showHelp()
};

function serve(): void
{
    echo "🚀 Starting OOPress development server...\n";
    echo "📍 http://localhost:8085\n";
    echo "Press Ctrl+C to stop.\n\n";
    system('php -S localhost:8085 -t public');
}

function makeModel(string $name): void
{
    if (empty($name)) {
        echo "❌ Please provide a model name\n";
        return;
    }
    
    $content = "<?php\n\ndeclare(strict_types=1);\n\nnamespace OOPress\\Models;\n\nuse OOPress\\Core\\Database\\Model;\n\nclass {$name} extends Model\n{\n    protected static string \$table = '" . strtolower($name) . "s';\n    \n    protected array \$hidden = [];\n    \n    protected array \$casts = [\n        'id' => 'int',\n    ];\n}\n";
    
    $path = __DIR__ . "/../src/Models/{$name}.php";
    file_put_contents($path, $content);
    echo "✅ Created model: src/Models/{$name}.php\n";
}

function makeController(string $name): void
{
    if (empty($name)) {
        echo "❌ Please provide a controller name\n";
        return;
    }
    
    $content = "<?php\n\ndeclare(strict_types=1);\n\nnamespace OOPress\\Controllers;\n\nuse OOPress\\Http\\Request;\nuse OOPress\\Http\\Response;\n\nclass {$name}\n{\n    public function index(Request \$request): Response\n    {\n        return new Response('{$name} index page');\n    }\n    \n    public function show(Request \$request, int \$id): Response\n    {\n        return new Response('Showing item ' . \$id);\n    }\n}\n";
    
    $path = __DIR__ . "/../src/Controllers/{$name}.php";
    file_put_contents($path, $content);
    echo "✅ Created controller: src/Controllers/{$name}.php\n";
}

function makeMiddleware(string $name): void
{
    if (empty($name)) {
        echo "❌ Please provide a middleware name\n";
        return;
    }
    
    $content = "<?php\n\ndeclare(strict_types=1);\n\nnamespace OOPress\\Http\\Middleware;\n\nuse OOPress\\Http\\Request;\nuse OOPress\\Http\\Response;\nuse OOPress\\Http\\MiddlewareInterface;\n\nclass {$name} implements MiddlewareInterface\n{\n    public function process(Request \$request, callable \$next): Response\n    {\n        // Add your middleware logic here\n        \n        return \$next(\$request);\n    }\n}\n";
    
    $path = __DIR__ . "/../src/Http/Middleware/{$name}.php";
    if (!is_dir(__DIR__ . '/../src/Http/Middleware')) {
        mkdir(__DIR__ . '/../src/Http/Middleware', 0755, true);
    }
    file_put_contents($path, $content);
    echo "✅ Created middleware: src/Http/Middleware/{$name}.php\n";
}

function makeMigration(string $name): void
{
    if (empty($name)) {
        echo "❌ Please provide a migration name\n";
        return;
    }
    
    $timestamp = date('Ymd_His');
    $filename = "{$timestamp}_{$name}.php";
    $content = "<?php\n\nuse Medoo\\Medoo;\n\nreturn new class {\n    public function up(Medoo \$db): void\n    {\n        // Add your migration code here\n        // Example: \$db->query(\"CREATE TABLE ...\");\n    }\n    \n    public function down(Medoo \$db): void\n    {\n        // Add your rollback code here\n        // Example: \$db->query(\"DROP TABLE ...\");\n    }\n};\n";
    
    $path = __DIR__ . "/../database/migrations/{$filename}";
    if (!is_dir(__DIR__ . '/../database/migrations')) {
        mkdir(__DIR__ . '/../database/migrations', 0755, true);
    }
    file_put_contents($path, $content);
    echo "✅ Created migration: database/migrations/{$filename}\n";
}

function migrate(): void
{
    echo "📦 Running migrations...\n\n";
    
    if (!file_exists(__DIR__ . '/../config/database.php')) {
        echo "❌ Database config not found. Please create config/database.php\n";
        return;
    }
    
    $db = require __DIR__ . '/../config/database.php';
    
    // Test database connection
    try {
        $db->query("SELECT 1");
        echo "✓ Database connection successful\n\n";
    } catch (Exception $e) {
        echo "❌ Database connection failed: " . $e->getMessage() . "\n";
        echo "Please check your .env database settings\n";
        return;
    }
    
    $migration = new OOPress\Core\Database\Migration($db);
    $migration->run(__DIR__ . '/../database/migrations');
    echo "\n✅ Migrations complete!\n";
}

function migrateRollback(string $steps = '1'): void
{
    $steps = (int)$steps;
    echo "⏪ Rolling back {$steps} migration(s)...\n\n";
    
    $db = require __DIR__ . '/../config/database.php';
    $migration = new OOPress\Core\Database\Migration($db);
    $migration->rollback($steps);
    echo "\n✅ Rollback complete!\n";
}

function migrateFresh(): void
{
    echo "🔄 Fresh migration...\n\n";
    
    $db = require __DIR__ . '/../config/database.php';
    $migration = new OOPress\Core\Database\Migration($db);
    
    echo "Rolling back all migrations...\n";
    $migration->rollback(1000);
    
    echo "\nRunning all migrations...\n";
    $migration->run(__DIR__ . '/../database/migrations');
    
    echo "\n✅ Fresh migration complete!\n";
}

function migrateStatus(): void
{
    echo "📊 Migration status\n\n";
    
    $db = require __DIR__ . '/../config/database.php';
    
    // Check if migrations table exists
    $tableExists = $db->query("SHOW TABLES LIKE 'migrations'")->rowCount() > 0;
    
    if (!$tableExists) {
        echo "No migrations have been run yet.\n";
        echo "Run 'php cli/oopress migrate' to create the migrations table.\n";
        return;
    }
    
    // Get executed migrations
    $executed = $db->select('migrations', '*', [
        'ORDER' => ['batch' => 'DESC', 'id' => 'DESC']
    ]);
    
    if (empty($executed)) {
        echo "No migrations have been run yet.\n";
    } else {
        echo "Executed migrations:\n";
        foreach ($executed as $mig) {
            echo "  • {$mig['migration']} (batch {$mig['batch']}) - {$mig['executed_at']}\n";
        }
    }
    
    // Get pending migrations - FIXED: compare without .php extension
    $migrationsDir = __DIR__ . '/../database/migrations';
    if (is_dir($migrationsDir)) {
        $files = glob($migrationsDir . '/*.php');
        $executedNames = array_column($executed, 'migration');
        
        // Remove .php extension from filenames for comparison
        $pending = [];
        foreach ($files as $file) {
            $filename = basename($file, '.php');  // Remove .php extension
            if (!in_array($filename, $executedNames)) {
                $pending[] = basename($file);  // Keep .php for display
            }
        }
        
        if (!empty($pending)) {
            echo "\nPending migrations:\n";
            foreach ($pending as $pend) {
                echo "  • {$pend}\n";
            }
        } else {
            echo "\nNo pending migrations.\n";
        }
    }
}

function dbSeed(): void
{
    echo "🌱 Seeding database...\n\n";
    
    $db = require __DIR__ . '/../config/database.php';
    $seeder = require __DIR__ . '/../database/seeders/DatabaseSeeder.php';
    $seeder->run($db);
    
    echo "\n✅ Seeding complete!\n";
}

function cacheClear(): void
{
    $cachePath = __DIR__ . '/../storage/cache';
    if (is_dir($cachePath)) {
        $files = glob($cachePath . '/*');
        foreach ($files as $file) {
            if (is_file($file)) {
                unlink($file);
            }
        }
        echo "✅ Cache cleared\n";
    } else {
        echo "ℹ️  Cache directory not found\n";
    }
}

function routeList(): void
{
    $routesFile = __DIR__ . '/../config/routes.php';
    if (!file_exists($routesFile)) {
        echo "❌ routes.php not found\n";
        return;
    }
    
    $routes = require $routesFile;
    
    echo "\n📋 Registered Routes:\n\n";
    foreach ($routes as $method => $methodRoutes) {
        foreach ($methodRoutes as $path => $handler) {
            $handlerStr = is_array($handler) ? implode('@', $handler) : (is_string($handler) ? $handler : 'Closure');
            echo sprintf("  %-7s %-30s %s\n", $method, $path, $handlerStr);
        }
    }
    echo "\n";
}

