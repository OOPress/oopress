# OOPress Environment Configuration
# Copy this file to .env and adjust for your setup

APP_NAME="OOPress"
APP_ENV=production           # Change to 'local' for development
APP_DEBUG=false             # Set to 'true' only on local/dev
APP_TIMEZONE=UTC

# Database Configuration
DB_TYPE=mysql
DB_HOST=localhost
DB_NAME=oopress
DB_USER=root
DB_PASS=your_password_here

# Mail Configuration (for password reset, notifications)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=user@example.com
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@oopress.com
MAIL_FROM_NAME="OOPress"

# Internationalization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_AVAILABLE_LOCALES=en,es,fr,de,it,pt

