{
  "name": "oopress/oopress",
  "description": "OOPress CMS - Modern object-oriented PHP CMS",
  "type": "project",
  "require": {
    "php": ">=8.2"
  },
  "autoload": {
    "psr-4": {
      "OOPress\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "classmap-authoritative": true
  }, 
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  }
}
