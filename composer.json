{
    "name": "oopress/oopress",
    "description": "OOPress CMS — Stability for developers. Transparency for site owners.",
    "type": "project",
    "license": "Apache-2.0",
    "homepage": "https://oopress.org",
    "support": {
        "issues": "https://github.com/OOPress/oopress/issues",
        "source": "https://github.com/OOPress/oopress"
    },
    "require": {
        "php": ">=8.2",
        "symfony/http-foundation": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/translation": "^7.0",
        "symfony/security-core": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/console": "^7.0",
        "doctrine/dbal": "^3.8",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "OOPress\\": "core/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OOPress\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse core --level=8"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
