<?php

/**
 * OOPress site settings
 *
 * Copy this file to settings.php and fill in your values.
 * settings.php is never committed to version control.
 */

declare(strict_types=1);

// Database
$settings['database'] = [
    'driver'   => 'pdo_mysql',   // pdo_mysql | pdo_pgsql | pdo_sqlite
    'host'     => 'localhost',
    'port'     => 3306,
    'dbname'   => 'oopress',
    'user'     => 'root',
    'password' => '',
    'prefix'   => 'oop_',        // table prefix — multisite-ready in future
    'charset'  => 'utf8mb4',
];

// Environment
$settings['env'] = 'production'; // production | development

// Security
$settings['secret'] = 'change-this-to-a-long-random-string';

