{% extends 'install/base.html.twig' %}

{% block content %}
<div class="install-complete">
    <h1>Installation Complete!</h1>
    
    <div class="success-icon">
        ✓
    </div>
    
    <p class="lead">
        OOPress has been successfully installed!
    </p>
    
    <div class="install-stats">
        <div class="stat">
            <span class="stat-value">{{ result.state.duration|round(2) }}</span>
            <span class="stat-label">Seconds</span>
        </div>
        <div class="stat">
            <span class="stat-value">{{ result.state.steps|length }}</span>
            <span class="stat-label">Steps Completed</span>
        </div>
        <div class="stat">
            <span class="stat-value">{{ result.admin_user_id }}</span>
            <span class="stat-label">Admin User ID</span>
        </div>
    </div>
    
    {% if result.warnings %}
    <div class="warnings">
        <h3>⚠️ Warnings</h3>
        <ul>
        {% for warning in result.warnings %}
            <li>{{ warning }}</li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}
    
    <div class="install-actions">
        <a href="{{ admin_url }}" class="button button-primary">Go to Admin Panel</a>
        <a href="{{ site_url }}" class="button">View Site</a>
    </div>
    
    <div class="next-steps">
        <h3>Next Steps</h3>
        <ul>
            <li>📝 <a href="{{ admin_url }}/content/types">Create your first content type</a></li>
            <li>🎨 <a href="{{ admin_url }}/appearance/themes">Customize your theme</a></li>
            <li>🔧 <a href="{{ admin_url }}/modules">Explore available modules</a></li>
            <li>📚 <a href="https://docs.oopress.org">Read the documentation</a></li>
        </ul>
    </div>
</div>
{% endblock %}

{% block styles %}
<style>
.install-complete {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
}

.success-icon {
    font-size: 5rem;
    width: 100px;
    height: 100px;
    background: #28a745;
    color: white;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 2rem auto;
}

.install-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 2rem 0;
}

.stat {
    text-align: center;
}

.stat-value {
    display: block;
    font-size: 2rem;
    font-weight: bold;
    color: #28a745;
}

.stat-label {
    font-size: 0.8rem;
    color: #666;
}

.warnings {
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 8px;
    padding: 1rem;
    margin: 2rem 0;
    text-align: left;
}

.warnings h3 {
    margin-top: 0;
    color: #856404;
}

.warnings ul {
    margin-bottom: 0;
}

.next-steps {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 1rem;
    margin: 2rem 0;
    text-align: left;
}

.next-steps h3 {
    margin-top: 0;
}

.next-steps ul {
    margin-bottom: 0;
    padding-left: 1.5rem;
}

.next-steps li {
    margin: 0.5rem 0;
}

.install-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 2rem 0;
}
</style>
{% endblock %}