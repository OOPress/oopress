{% extends 'install/base.html.twig' %}

{% block content %}
<div class="install-requirements">
    <h1>System Requirements</h1>
    
    <p>OOPress requires the following components to function properly.</p>
    
    <div class="requirements-list">
        {% for req in requirements %}
        <div class="requirement {{ req.passed ? 'passed' : (req.critical ? 'failed' : 'warning') }}">
            <div class="requirement-name">
                {{ req.name }}
                {% if not req.critical %}
                <span class="optional">(optional)</span>
                {% endif %}
            </div>
            <div class="requirement-status">
                {% if req.passed %}
                ✓ {{ req.current }}
                {% else %}
                ✗ {{ req.current }}
                {% endif %}
            </div>
            <div class="requirement-detail">
                Required: {{ req.required }}
            </div>
        </div>
        {% endfor %}
    </div>
    
    <div class="install-actions">
        {% if all_passed %}
        <a href="/install/database" class="button button-primary">Continue</a>
        {% else %}
        <div class="error-message">
            <strong>⚠️ Please fix the requirements above before continuing.</strong>
        </div>
        <a href="/install/requirements" class="button">Check Again</a>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block styles %}
<style>
.requirements-list {
    margin: 2rem 0;
}

.requirement {
    display: flex;
    align-items: center;
    padding: 0.75rem;
    border-bottom: 1px solid #eee;
}

.requirement.passed {
    background: #d4edda;
}

.requirement.failed {
    background: #f8d7da;
}

.requirement.warning {
    background: #fff3cd;
}

.requirement-name {
    flex: 2;
    font-weight: bold;
}

.optional {
    font-weight: normal;
    font-size: 0.8rem;
    color: #666;
    margin-left: 0.5rem;
}

.requirement-status {
    flex: 1;
    text-align: center;
}

.requirement-detail {
    flex: 1;
    text-align: right;
    font-size: 0.8rem;
    color: #666;
}

.error-message {
    background: #f8d7da;
    color: #721c24;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
    text-align: center;
}

.button {
    margin: 0 0.5rem;
}
</style>
{% endblock %}