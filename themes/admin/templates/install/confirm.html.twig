{% extends 'install/base.html.twig' %}

{% block content %}
<div class="install-confirm">
    <h1>Confirm Installation</h1>
    
    <p>Please review your settings before installing OOPress.</p>
    
    <div class="config-summary">
        <h2>Site Settings</h2>
        <table>
            <tr>
                <th>Site Name:</th>
                <td>{{ config.site_name }}</td>
            </tr>
            <tr>
                <th>Site URL:</th>
                <td>{{ config.site_url }}</td>
            </tr>
            <tr>
                <th>Site Email:</th>
                <td>{{ config.site_email }}</td>
            </tr>
            <tr>
                <th>Language:</th>
                <td>{{ config.language|default('en') }}</td>
            </tr>
            <tr>
                <th>Timezone:</th>
                <td>{{ config.timezone|default('UTC') }}</td>
            </tr>
        </table>
        
        <h2>Database Settings</h2>
        <table>
            <tr>
                <th>Database Type:</th>
                <td>{{ config.db_driver|default('pdo_mysql') }}</td>
            </tr>
            <tr>
                <th>Database Host:</th>
                <td>{{ config.db_host }}</td>
            </tr>
            <tr>
                <th>Database Name:</th>
                <td>{{ config.db_name }}</td>
            </tr>
            <tr>
                <th>Database User:</th>
                <td>{{ config.db_user }}</td>
            </tr>
            <tr>
                <th>Table Prefix:</th>
                <td>{{ config.db_prefix|default('oop_') }}</td>
            </tr>
        </table>
        
        <h2>Admin User</h2>
        <table>
            <tr>
                <th>Username:</th>
                <td>{{ config.admin_username }}</td>
            </tr>
            <tr>
                <th>Email:</th>
                <td>{{ config.admin_email }}</td>
            </tr>
        </table>
    </div>
    
    <div class="gdpr-notice">
        <h3>🔒 GDPR Notice</h3>
        <p>
            By installing OOPress, you agree that all data will be stored locally on your server.
            OOPress does not send any personal data to external services by default.
        </p>
        <p>
            <input type="checkbox" id="gdpr_consent" required>
            <label for="gdpr_consent">I confirm that I have read and understood this notice.</label>
        </p>
    </div>
    
    <form method="POST" class="install-form" onsubmit="return document.getElementById('gdpr_consent').checked">
        <div class="install-actions">
            <a href="/install/admin" class="button">Back</a>
            <button type="submit" name="confirm" value="yes" class="button button-primary">Install OOPress</button>
        </div>
    </form>
</div>
{% endblock %}

{% block styles %}
{{ parent() }}
<style>
.config-summary {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 1rem;
    margin: 1rem 0;
}

.config-summary h2 {
    font-size: 1.1rem;
    margin: 1rem 0 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #dee2e6;
}

.config-summary table {
    width: 100%;
    margin-bottom: 1rem;
}

.config-summary th {
    text-align: left;
    width: 40%;
    padding: 0.5rem;
    font-weight: normal;
    color: #666;
}

.config-summary td {
    padding: 0.5rem;
    font-family: monospace;
}

.gdpr-notice {
    background: #e3f2fd;
    border-radius: 8px;
    padding: 1rem;
    margin: 1rem 0;
}

.gdpr-notice input {
    margin-right: 0.5rem;
}
</style>
{% endblock %}