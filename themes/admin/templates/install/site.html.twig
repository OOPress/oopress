{% extends 'install/base.html.twig' %}

{% block content %}
<div class="install-site">
    <h1>Site Configuration</h1>
    
    <p>Configure your site settings.</p>
    
    {% if errors %}
    <div class="error-message">
        <strong>Please fix the following errors:</strong>
        <ul>
        {% for field, error in errors %}
            <li>{{ error }}</li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}
    
    <form method="POST" class="install-form">
        <div class="form-group">
            <label for="site_name">Site Name</label>
            <input type="text" name="site_name" id="site_name" value="{{ saved.site_name|default('My OOPress Site') }}" required>
            <small>The name of your website</small>
        </div>
        
        <div class="form-group">
            <label for="site_url">Site URL</label>
            <input type="url" name="site_url" id="site_url" value="{{ saved.site_url|default(site_url) }}" required>
            <small>The public URL of your site (e.g., https://example.com)</small>
        </div>
        
        <div class="form-group">
            <label for="site_email">Site Email</label>
            <input type="email" name="site_email" id="site_email" value="{{ saved.site_email }}" required>
            <small>Email address for system notifications</small>
        </div>
        
        <div class="form-group">
            <label for="language">Default Language</label>
            <select name="language" id="language">
                {% for code, name in languages %}
                <option value="{{ code }}" {% if saved.language|default('en') == code %}selected{% endif %}>
                    {{ name }}
                </option>
                {% endfor %}
            </select>
        </div>
        
        <div class="form-group">
            <label for="timezone">Timezone</label>
            <select name="timezone" id="timezone" size="5">
                {% for zone, name in timezones %}
                <option value="{{ zone }}" {% if saved.timezone|default('UTC') == zone %}selected{% endif %}>
                    {{ name }}
                </option>
                {% endfor %}
            </select>
        </div>
        
        <div class="install-actions">
            <a href="/install/database" class="button">Back</a>
            <button type="submit" class="button button-primary">Continue</button>
        </div>
    </form>
</div>
{% endblock %}

{% block styles %}
{{ parent() }}
<style>
select[size] {
    height: auto;
    min-height: 150px;
}
</style>
{% endblock %}