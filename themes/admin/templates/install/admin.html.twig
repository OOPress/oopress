{% extends 'install/base.html.twig' %}

{% block content %}
<div class="install-admin">
    <h1>Admin User</h1>
    
    <p>Create your administrator account.</p>
    
    {% if errors %}
    <div class="error-message">
        <strong>Please fix the following errors:</strong>
        <ul>
        {% for field, error in errors %}
            <li>{{ error }}</li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}
    
    <form method="POST" class="install-form">
        <div class="form-group">
            <label for="admin_username">Username</label>
            <input type="text" name="admin_username" id="admin_username" value="{{ saved.admin_username|default('admin') }}" required>
            <small>At least 3 characters</small>
        </div>
        
        <div class="form-group">
            <label for="admin_email">Email Address</label>
            <input type="email" name="admin_email" id="admin_email" value="{{ saved.admin_email }}" required>
        </div>
        
        <div class="form-group">
            <label for="admin_password">Password</label>
            <input type="password" name="admin_password" id="admin_password" required>
            <small>
                <ul>
                    <li>At least 8 characters</li>
                    <li>One uppercase letter</li>
                    <li>One lowercase letter</li>
                    <li>One number</li>
                </ul>
            </small>
        </div>
        
        <div class="form-group">
            <label for="admin_password_confirm">Confirm Password</label>
            <input type="password" name="admin_password_confirm" id="admin_password_confirm" required>
        </div>
        
        <div class="password-strength">
            <div class="strength-meter"></div>
            <span class="strength-text"></span>
        </div>
        
        <div class="install-actions">
            <a href="/install/site" class="button">Back</a>
            <button type="submit" class="button button-primary">Continue</button>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
document.getElementById('admin_password').addEventListener('input', function() {
    var password = this.value;
    var strength = 0;
    
    if (password.length >= 8) strength++;
    if (password.match(/[A-Z]/)) strength++;
    if (password.match(/[a-z]/)) strength++;
    if (password.match(/[0-9]/)) strength++;
    
    var meter = document.querySelector('.strength-meter');
    var text = document.querySelector('.strength-text');
    
    meter.style.width = (strength * 25) + '%';
    
    if (strength <= 1) {
        meter.style.background = '#dc3545';
        text.textContent = 'Weak';
    } else if (strength <= 3) {
        meter.style.background = '#ffc107';
        text.textContent = 'Medium';
    } else {
        meter.style.background = '#28a745';
        text.textContent = 'Strong';
    }
});
</script>
{% endblock %}

{% block styles %}
{{ parent() }}
<style>
.password-strength {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
}

.strength-meter {
    height: 4px;
    background: #e9ecef;
    border-radius: 2px;
    transition: width 0.3s, background 0.3s;
    width: 0;
}

.strength-text {
    font-size: 0.8rem;
    color: #666;
}
</style>
{% endblock %}