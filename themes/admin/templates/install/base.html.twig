<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | OOPress Installation</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 2rem;
        }
        
        .install-container {
            max-width: 1000px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .install-header {
            background: #2c3e50;
            color: white;
            padding: 1.5rem;
        }
        
        .install-header h1 {
            margin: 0;
            font-size: 1.5rem;
        }
        
        .install-progress {
            background: #f8f9fa;
            padding: 1rem;
            border-bottom: 1px solid #dee2e6;
        }
        
        .progress-steps {
            display: flex;
            justify-content: space-between;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        
        .progress-step {
            flex: 1;
            text-align: center;
            padding: 0.5rem;
            color: #6c757d;
            position: relative;
        }
        
        .progress-step.completed {
            color: #28a745;
        }
        
        .progress-step.active {
            color: #007bff;
            font-weight: bold;
        }
        
        .progress-step::after {
            content: '';
            position: absolute;
            top: 50%;
            right: -50%;
            width: 100%;
            height: 2px;
            background: #dee2e6;
            transform: translateY(-50%);
        }
        
        .progress-step:last-child::after {
            display: none;
        }
        
        .progress-step.completed::after {
            background: #28a745;
        }
        
        .install-content {
            padding: 2rem;
            min-height: 500px;
        }
        
        .install-footer {
            background: #f8f9fa;
            padding: 1rem;
            text-align: center;
            border-top: 1px solid #dee2e6;
            font-size: 0.8rem;
            color: #6c757d;
        }
        
        @media (max-width: 768px) {
            body {
                padding: 1rem;
            }
            
            .progress-steps {
                flex-wrap: wrap;
            }
            
            .progress-step {
                flex: auto;
                min-width: 80px;
            }
            
            .progress-step::after {
                display: none;
            }
        }
        
        {% block styles %}{% endblock %}
    </style>
</head>
<body>
    <div class="install-container">
        <div class="install-header">
            <h1>OOPress Installation</h1>
        </div>
        
        <div class="install-progress">
            <ul class="progress-steps">
                {% for step_key, step_name in steps %}
                <li class="progress-step 
                    {% if current_step_index > loop.index0 %}completed{% endif %}
                    {% if current_step_index == loop.index0 %}active{% endif %}
                ">
                    {{ step_name }}
                </li>
                {% endfor %}
            </ul>
        </div>
        
        <div class="install-content">
            {% block content %}{% endblock %}
        </div>
        
        <div class="install-footer">
            <p>OOPress CMS — Modern, Transparent, GDPR Compliant</p>
            <p>© {{ "now"|date('Y') }} OOPress. All rights reserved.</p>
        </div>
    </div>
    
    {% block scripts %}{% endblock %}
</body>
</html>